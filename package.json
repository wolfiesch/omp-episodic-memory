{
  "name": "omp-episodic-memory",
  "version": "1.1.0",
  "type": "module",
  "description": "Local-first experience memory for coding agents: forensic search + reviewable decisions, runbooks, and gotchas over Oh My Pi session transcripts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wolfiesch/omp-episodic-memory.git"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "omp-episodic": "dist/cli.js",
    "omp-episodic-mcp": "dist/mcp-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "FORMAT.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "cli": "node --import tsx src/cli.ts",
    "eval": "node --import tsx src/cli.ts eval",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.0.0",
    "sqlite-vec": "^0.1.6",
    "zod": "3"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.11"
  }
}
